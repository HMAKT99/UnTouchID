{
    "manifest_version": 3,
    "name": "TouchBridge",
    "version": "0.1.0",
    "description": "Authenticate browser autofill and WebAuthn via your iPhone's biometrics.",
    "permissions": ["nativeMessaging"],
    "background": {
        "scripts": ["background.js"],
        "persistent": false
    },
    "content_scripts": [{
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "run_at": "document_idle"
    }],
    "icons": {
        "48": "icon-48.png",
        "128": "icon-128.png"
    }
}
